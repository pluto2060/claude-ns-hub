  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'VD=$HOME/.local/share/claude-vault; PY=$VD/venv/bin/python; \\\nif [ -x \"$PY\" ] && $PY -c \"import sentence_transformers\" 2>/dev/null; then \\\n  python3 -c \"import socket,os; s=socket.socket(socket.AF_UNIX); s.settimeout(0.3); s.connect(os.path.expanduser(\\\"~/.local/share/claude-vault/vec-daemon.sock\\\"))\" 2>/dev/null || { rm -f $VD/vec-daemon.sock; nohup $PY $VD/vec-daemon.py > /tmp/vec-daemon.log 2>&1 & }; \\\n  if [ \"${CTX_BGE_ENABLE}\" = \"1\" ]; then python3 -c \"import socket,os; s=socket.socket(socket.AF_UNIX); s.settimeout(0.3); s.connect(os.path.expanduser(\\\"~/.local/share/claude-vault/bge-daemon.sock\\\"))\" 2>/dev/null || { rm -f $VD/bge-daemon.sock; nohup $PY $VD/bge-daemon.py > /tmp/bge-daemon.log 2>&1 & }; fi; \\\nelse \\\n  echo \"[CTX] vec-daemon venv not found — semantic layer disabled\" > /tmp/ctx-daemon-hint.txt; \\\nfi'",
            "async": true
          },
          {
            "type": "command",
            "command": "bash -c '[ -f /tmp/wsl-expose-6901.boot ] || { /home/desk-1/.claude/bin/wsl-expose 6901 > /tmp/wsl-expose-6901.log 2>&1 && touch /tmp/wsl-expose-6901.boot; }'",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/stop-decision-capture.py"
          },
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/pre-compact-save.js"
          },
          {
            "type": "command",
            "command": "bash $HOME/.local/share/claude-vault/claude-vault-incremental.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CHAT_MEMORY_SCOPE=global python3 $HOME/.claude/hooks/chat-memory.py"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/bm25-memory.py --rich"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/memory-keyword-trigger.py"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/close-popup.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/subagent_tracker.py",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_EVENT=SubagentStop python3 $HOME/.claude/hooks/subagent_tracker.py",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq '. + {\"matcher\":\"permission_prompt\"}' | bash $HOME/.claude/hooks/windows-notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/stop-decision-capture.py"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/stop-playwright-detect.py"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/windows-stop.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "echo \"{}\" | bash $HOME/.local/share/claude-vault/claude-vault-incremental.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/utility-rate.py",
            "async": true
          },
          {
            "type": "command",
            "command": "/home/desk-1/.local/bin/backup-vault-filtered-gdrive.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/northstar-session-update.py",
            "async": true
          }
        ]
      }
    ],
