# NS Hub Environment Variables Template
# Copy to ~/.config/hub/env and fill in your values

# Server port (default: 9001)
HUB_PORT=9001

# Turso cloud DB (for milestone sync across devices — optional)
# Create at https://turso.io → turso db create ns-hub-{yourname}
TURSO_DATABASE_URL=libsql://your-db-name.aws-us-west-2.turso.io
TURSO_AUTH_TOKEN=your-turso-token-here

# Telemetry DB (optional — usage analytics)
HUB_TELEMETRY_URL=
HUB_TELEMETRY_TOKEN=

# Email notifications via Naver (optional)
NAVER_MAIL_USER=your-id@naver.com
NAVER_APP_PW=your-app-password
